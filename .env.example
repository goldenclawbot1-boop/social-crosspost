# Social CrossPost — Environment Configuration
# Copy to .env and fill in values

# App
APP_NAME=Social CrossPost
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DATABASE_URL=sqlite:///./crosspost.db
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Base URL (for OAuth callbacks)
BASE_URL=http://localhost:8000

# Twitter/X OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook / Instagram (Meta Developer)
META_APP_ID=
META_APP_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# YouTube / Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# S3 / R2 for production media storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
